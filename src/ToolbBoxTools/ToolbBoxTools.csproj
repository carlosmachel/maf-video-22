<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Azure.AI.Projects" Version="2.1.0-beta.3" />
      <PackageReference Include="dotenv.net" Version="4.0.2" />
      <PackageReference Include="Microsoft.Agents.AI" Version="1.9.0" />
      <PackageReference Include="Microsoft.Agents.AI.Foundry" Version="1.9.0-preview.260603.1" />
      <PackageReference Include="ModelContextProtocol" Version="1.4.0" />
    </ItemGroup>

    <ItemGroup>
      <None Update=".env">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Compile Remove="sample.cs" />
      <Content Include="sample.cs">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

</Project>
